    <changeSet id="20260319001000-3" author="assistant" context="dev,test">
        <!-- Map application Spring Security authorities to security engine roles via authority names.
             admin -> STOCKKEEPER_ROLE
             user  -> ACCOUNTANT_ROLE -->

        <!-- Add new authorities that correspond to our role codes -->
        <insert tableName="jhi_authority">
            <column name="name" value="STOCKKEEPER_ROLE"/>
        </insert>
        <insert tableName="jhi_authority">
            <column name="name" value="ACCOUNTANT_ROLE"/>
        </insert>

        <!-- admin user (id=1) gets STOCKKEEPER_ROLE -->
        <insert tableName="jhi_user_authority">
            <column name="user_id" valueNumeric="1"/>
            <column name="authority_name" value="STOCKKEEPER_ROLE"/>
        </insert>

        <!-- user (id=2) gets ACCOUNTANT_ROLE -->
        <insert tableName="jhi_user_authority">
            <column name="user_id" valueNumeric="2"/>
            <column name="authority_name" value="ACCOUNTANT_ROLE"/>
        </insert>
    </changeSet>
